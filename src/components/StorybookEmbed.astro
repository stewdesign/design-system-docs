---
const { story, viewMode = 'docs' } = Astro.props;
const base = import.meta.env.PUBLIC_STORYBOOK_URL;
---

{base ? (
  <div style="border: 1px solid #ccc; border-radius: 4px; overflow: hidden; margin: 1rem 0;">
    <iframe
      src={`${base}/iframe.html?id=${story}&viewMode=${viewMode}`}
      style="width: 100%; height: 600px; border: none;"
      title={`Storybook: ${story}`}
    />
  </div>
) : (
  <div style="border: 2px dashed #ccc; padding: 2rem; text-align: center;
               color: #666; border-radius: 4px; margin: 1rem 0;">
    <p><strong>Storybook embed</strong></p>
    <p style="font-size: 0.875rem;">
      Set PUBLIC_STORYBOOK_URL to show a live component here.
    </p>
  </div>
)}