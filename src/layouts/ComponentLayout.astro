---
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

const {
  title,
  description,
  storybookUrl,
  figmaUrl,
  previewImage,
} = Astro.props;
---
<html lang="en">
  <Header title={title} />
  <body>
    <main>
      <h1>{title}</h1>
      <p>{description}</p>
      <div>
        {storybookUrl && <a href={storybookUrl} target="_blank" rel="noopener">View in Storybook</a>}
        {figmaUrl && <a href={figmaUrl} target="_blank" rel="noopener">Open in Figma</a>}
      </div>
      {previewImage && <img src={previewImage} alt={`${title} component preview`} />}
      <slot />
    </main>
    <Footer />
  </body>
</html>