---
import StorybookEmbed from '../../components/StorybookEmbed.astro';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Radio — AA Design System</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
        color: #00081c;
      }
      .back {
        display: inline-block;
        margin-bottom: 2rem;
        color: #666;
        text-decoration: none;
        font-size: 0.875rem;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
      }
      th,
      td {
        padding: 8px 12px;
        border: 1px solid #ddd;
        text-align: left;
      }
      th {
        background: #f5f5f5;
      }
      .guidance {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1.5rem;
        margin: 1.5rem 0;
      }
      .guidance-col h3 {
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
      }
      .guidance-col ul {
        margin: 0;
        padding-left: 1.25rem;
        font-size: 0.875rem;
      }
      .guidance-col li {
        margin-bottom: 0.4rem;
      }
      .do h3 {
        color: #00703c;
      }
      .dont h3 {
        color: #d4351c;
      }
      .general h3 {
        color: #00081c;
      }
    </style>
  </head>
  <body>
    <a href={`${import.meta.env.BASE_URL}`} class="back">&larr; Home</a>
    <h1>Radio</h1>
    <p>
      A radio lets users select a single item from a mutually exclusive list.
    </p>
   
    <h2>Live component</h2>
    <StorybookEmbed story="components-radio--default-group" viewMode="story" />
    
    <h2>Usage</h2>
    <div class="guidance">
      <div class="guidance-col do">
        <h3>✓ Use radio input</h3>
        <ul>
          <li>When only one option can be selected at any time</li>
          <li>If all options are visible at the same time</li>
          <li>When the choice is clear and mutually exclusive</li>
        </ul>
      </div>
      <div class="guidance-col dont">
        <h3>✕ Don't use radio input</h3>
        <ul>
          <li>
            When more than one option can be selected — use checkboxes instead
          </li>
          <li>If the choice is optional or can be skipped</li>
          <li>When options change based on earlier answers</li>
          <li>If there are more than 6 options</li>
        </ul>
      </div>
      <div class="guidance-col general">
        <h3>ℹ General guidance</h3>
        <ul>
          <li>Always preselect a safe default where possible</li>
          <li>Keep labels short, specific, and scannable</li>
          <li>Stack options vertically for easier reading</li>
          <li>Make the whole row clickable, not just the circle</li>
        </ul>
      </div>
    </div>

    <h2>Anatomy</h2>
    <table>
      <tr><th>#</th><th>Element</th><th>Required</th></tr>
      <tr><td>1</td><td>Radio input</td><td>Yes</td></tr>
      <tr><td>2</td><td>Label</td><td>Yes</td></tr>
      <tr><td>3</td><td>Description</td><td>No</td></tr>
    </table>

    <h2>States</h2>
    <table>
      <tr><th>State</th><th>Description</th></tr>
      <tr>
        <td>Default</td>
        <td
          >Unselected radio in its resting state. Displays label and optional
          description.</td
        >
      </tr>
      <tr>
        <td>Hover</td>
        <td>Shown when a user moves their cursor over the radio row.</td>
      </tr>
      <tr>
        <td>Selected</td>
        <td>Indicates the user's active choice within the group.</td>
      </tr>
      <tr>
        <td>Focus</td>
        <td
          >Shown when a user tabs to the input. Designed to conform to
          accessibility standards.</td
        >
      </tr>
    </table>

    <h2>Accessibility</h2>
    <ul>
      <li>
        Radio buttons must be grouped using a <code>fieldset</code> and <code
          >legend</code
        > to provide context for screen readers
      </li>
      <li>Each radio must have an associated <code>label</code> element</li>
      <li>The full row must be clickable — not just the radio circle</li>
      <li>Focus state must be clearly visible and meet WCAG 2.4.11</li>
      <li>Do not rely on colour alone to indicate selection state</li>
    </ul>
  </body>
</html>
